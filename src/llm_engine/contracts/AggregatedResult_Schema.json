{
  "$defs": {
    "AggregatedAnalysis": {
      "properties": {
        "summary_scores": {
          "$ref": "#/$defs/SummaryScores"
        },
        "overall_strengths": {
          "items": {
            "type": "string"
          },
          "minItems": 10,
          "title": "Overall Strengths",
          "type": "array"
        },
        "overall_issues": {
          "items": {
            "type": "string"
          },
          "minItems": 10,
          "title": "Overall Issues",
          "type": "array"
        },
        "overall_evidences": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "minItems": 8,
          "title": "Overall Evidences",
          "type": "array"
        }
      },
      "required": [
        "summary_scores",
        "overall_strengths",
        "overall_issues",
        "overall_evidences"
      ],
      "title": "AggregatedAnalysis",
      "type": "object"
    },
    "Evidence": {
      "properties": {
        "item": {
          "description": "13개 평가 항목 키 중 하나 (예: learning_objective_intro).",
          "title": "Item",
          "type": "string"
        },
        "quote": {
          "description": "원문 발화를 그대로 인용. 반드시 한국어 원문.",
          "minLength": 1,
          "title": "Quote",
          "type": "string"
        },
        "reason": {
          "description": "이 인용구가 점수의 근거가 되는 이유를 반드시 한국어로 작성.",
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "item",
        "quote",
        "reason"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "SummaryConceptClarityScores": {
      "properties": {
        "concept_definition": {
          "title": "Concept Definition",
          "type": "number"
        },
        "analogy_example_usage": {
          "title": "Analogy Example Usage",
          "type": "number"
        },
        "prerequisite_check": {
          "title": "Prerequisite Check",
          "type": "number"
        }
      },
      "required": [
        "concept_definition",
        "analogy_example_usage",
        "prerequisite_check"
      ],
      "title": "SummaryConceptClarityScores",
      "type": "object"
    },
    "SummaryInteractionScores": {
      "properties": {
        "participation_induction": {
          "title": "Participation Induction",
          "type": "number"
        },
        "question_response_sufficiency": {
          "title": "Question Response Sufficiency",
          "type": "number"
        }
      },
      "required": [
        "participation_induction",
        "question_response_sufficiency"
      ],
      "title": "SummaryInteractionScores",
      "type": "object"
    },
    "SummaryLectureStructureScores": {
      "properties": {
        "learning_objective_intro": {
          "anyOf": [
            {
              "maximum": 5.0,
              "minimum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "통합 점수. N/A만 있는 경우 null",
          "title": "Learning Objective Intro"
        },
        "previous_lesson_linkage": {
          "anyOf": [
            {
              "maximum": 5.0,
              "minimum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "통합 점수. N/A만 있는 경우 null",
          "title": "Previous Lesson Linkage"
        },
        "explanation_sequence": {
          "maximum": 5.0,
          "minimum": 1.0,
          "title": "Explanation Sequence",
          "type": "number"
        },
        "key_point_emphasis": {
          "maximum": 5.0,
          "minimum": 1.0,
          "title": "Key Point Emphasis",
          "type": "number"
        },
        "closing_summary": {
          "anyOf": [
            {
              "maximum": 5.0,
              "minimum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "통합 점수. N/A만 있는 경우 null",
          "title": "Closing Summary"
        }
      },
      "required": [
        "explanation_sequence",
        "key_point_emphasis"
      ],
      "title": "SummaryLectureStructureScores",
      "type": "object"
    },
    "SummaryPracticeLinkageScores": {
      "properties": {
        "example_appropriateness": {
          "title": "Example Appropriateness",
          "type": "number"
        },
        "practice_transition": {
          "title": "Practice Transition",
          "type": "number"
        },
        "error_handling": {
          "title": "Error Handling",
          "type": "number"
        }
      },
      "required": [
        "example_appropriateness",
        "practice_transition",
        "error_handling"
      ],
      "title": "SummaryPracticeLinkageScores",
      "type": "object"
    },
    "SummaryScores": {
      "properties": {
        "lecture_structure": {
          "$ref": "#/$defs/SummaryLectureStructureScores"
        },
        "concept_clarity": {
          "$ref": "#/$defs/SummaryConceptClarityScores"
        },
        "practice_linkage": {
          "$ref": "#/$defs/SummaryPracticeLinkageScores"
        },
        "interaction": {
          "$ref": "#/$defs/SummaryInteractionScores"
        }
      },
      "required": [
        "lecture_structure",
        "concept_clarity",
        "practice_linkage",
        "interaction"
      ],
      "title": "SummaryScores",
      "type": "object"
    }
  },
  "properties": {
    "llm_aggregated_analysis": {
      "$ref": "#/$defs/AggregatedAnalysis"
    }
  },
  "required": [
    "llm_aggregated_analysis"
  ],
  "title": "AggregatedResult",
  "type": "object"
}