{
  "$defs": {
    "ChunkScores": {
      "properties": {
        "lecture_structure": {
          "$ref": "#/$defs/LectureStructureScores"
        },
        "concept_clarity": {
          "$ref": "#/$defs/ConceptClarityScores"
        },
        "practice_linkage": {
          "$ref": "#/$defs/PracticeLinkageScores"
        },
        "interaction": {
          "$ref": "#/$defs/InteractionScores"
        }
      },
      "required": [
        "lecture_structure",
        "concept_clarity",
        "practice_linkage",
        "interaction"
      ],
      "title": "ChunkScores",
      "type": "object"
    },
    "ConceptClarityScores": {
      "properties": {
        "concept_definition": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Concept Definition",
          "type": "integer"
        },
        "analogy_example_usage": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Analogy Example Usage",
          "type": "integer"
        },
        "prerequisite_check": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Prerequisite Check",
          "type": "integer"
        }
      },
      "required": [
        "concept_definition",
        "analogy_example_usage",
        "prerequisite_check"
      ],
      "title": "ConceptClarityScores",
      "type": "object"
    },
    "Evidence": {
      "properties": {
        "item": {
          "description": "13개 평가 항목 키 중 하나 (예: learning_objective_intro).",
          "title": "Item",
          "type": "string"
        },
        "quote": {
          "description": "원문 발화를 그대로 인용. 반드시 한국어 원문.",
          "minLength": 1,
          "title": "Quote",
          "type": "string"
        },
        "reason": {
          "description": "이 인용구가 점수의 근거가 되는 이유를 반드시 한국어로 작성.",
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "item",
        "quote",
        "reason"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "InteractionScores": {
      "properties": {
        "participation_induction": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Participation Induction",
          "type": "integer"
        },
        "question_response_sufficiency": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Question Response Sufficiency",
          "type": "integer"
        }
      },
      "required": [
        "participation_induction",
        "question_response_sufficiency"
      ],
      "title": "InteractionScores",
      "type": "object"
    },
    "LectureStructureScores": {
      "properties": {
        "learning_objective_intro": {
          "anyOf": [
            {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "1~5점 척도. 해당 청크에서 평가 불가 시 null(N/A)",
          "title": "Learning Objective Intro"
        },
        "previous_lesson_linkage": {
          "anyOf": [
            {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "1~5점 척도. 해당 청크에서 평가 불가 시 null(N/A)",
          "title": "Previous Lesson Linkage"
        },
        "explanation_sequence": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Explanation Sequence",
          "type": "integer"
        },
        "key_point_emphasis": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Key Point Emphasis",
          "type": "integer"
        },
        "closing_summary": {
          "anyOf": [
            {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "1~5점 척도. 해당 청크에서 평가 불가 시 null(N/A)",
          "title": "Closing Summary"
        }
      },
      "required": [
        "explanation_sequence",
        "key_point_emphasis"
      ],
      "title": "LectureStructureScores",
      "type": "object"
    },
    "PracticeLinkageScores": {
      "properties": {
        "example_appropriateness": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Example Appropriateness",
          "type": "integer"
        },
        "practice_transition": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Practice Transition",
          "type": "integer"
        },
        "error_handling": {
          "description": "1~5점 척도",
          "maximum": 5,
          "minimum": 1,
          "title": "Error Handling",
          "type": "integer"
        }
      },
      "required": [
        "example_appropriateness",
        "practice_transition",
        "error_handling"
      ],
      "title": "PracticeLinkageScores",
      "type": "object"
    }
  },
  "properties": {
    "chunk_id": {
      "minimum": 1,
      "title": "Chunk Id",
      "type": "integer"
    },
    "start_time": {
      "title": "Start Time",
      "type": "string"
    },
    "end_time": {
      "title": "End Time",
      "type": "string"
    },
    "scores": {
      "$ref": "#/$defs/ChunkScores"
    },
    "strengths": {
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "title": "Strengths",
      "type": "array"
    },
    "issues": {
      "items": {
        "type": "string"
      },
      "minItems": 5,
      "title": "Issues",
      "type": "array"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/Evidence"
      },
      "title": "Evidence",
      "type": "array"
    }
  },
  "required": [
    "chunk_id",
    "start_time",
    "end_time",
    "scores",
    "strengths",
    "issues",
    "evidence"
  ],
  "title": "ChunkResult",
  "type": "object"
}